# Modo de upstream do BFF: 'services' (dev — chama os 3 microsserviços) ou 'apim' (prod — gateway único)
UPSTREAM_MODE=services
# URL única do APIM (obrigatória quando UPSTREAM_MODE=apim)
APIM_BASE_URL=
# URLs dos microsserviços em dev (usadas quando UPSTREAM_MODE=services)
USERS_API_URL=http://localhost:5001
DONATIONS_API_URL=http://localhost:5003
PAYMENTS_API_URL=http://localhost:5002
# Flags de fallback mock (lacunas de backend) — 'true' ativa o gateway mock
MOCK_DONOR_CAMPAIGNS=false
MOCK_MY_DONATIONS=false
